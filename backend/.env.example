# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Canonical chapter id assigned by Merge Team (example for GIFT team)
CHAPTER_ID=grade8_linear_eq

# Optional fallback aliases tried only when upstream returns chapter_id metadata mismatch
CHAPTER_ID_ALIASES=grade8_linear_equations_one_variable,grade8-linear-equations-one-variable
